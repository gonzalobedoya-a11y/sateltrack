# =====================================================================
# SATELTRACK - Variables de entorno
# =====================================================================
# IMPORTANTE: Este archivo se llama .env.local y NUNCA debe subirse a Git.
# Ya está incluido en .gitignore.
# =====================================================================

# Tu Project URL de Supabase
NEXT_PUBLIC_SUPABASE_URL=https://vnewexrbjbsxxlmtdhtg.supabase.co

# Tu publishable/anon key (empieza con sb_publishable_... o eyJ...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=PEGA_AQUI_TU_PUBLISHABLE_KEY

# Tu service_role key (⚠️ SECRETA - solo se usa en el backend)
SUPABASE_SERVICE_ROLE_KEY=PEGA_AQUI_TU_SERVICE_ROLE_KEY

# Nombre de la app (para mostrar en la UI)
NEXT_PUBLIC_APP_NAME=GPS SATELTRACK
